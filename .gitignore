# ─── Python ────────────────────────────────────────────────
# Byte-compiled / optimized / cache files
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# ─── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Databases (created at runtime) ────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── Environment variables / secrets ───────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ─── Logs ──────────────────────────────────────────────────
*.log
logs/

# ─── Testing / coverage caches ─────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ─── IDE / editor / tooling ────────────────────────────────
.vscode/
.idea/
*.swp

# ─── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
